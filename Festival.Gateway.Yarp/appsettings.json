{
  "ReverseProxy": {
    "Routes": {
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/orders/{**catch-all}"
          }
        ]
      },
      "price-route": {
        "ClusterId": "price-cluster",
        "Match": {
          "Path": "/prices/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/prices/{**catch-all}"
          }
        ]
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/search/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/search/{**catch-all}"
          }
        ]
      },
      "ticket-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "/tickets/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/tickets/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "price-cluster": {
        "Destinations": {
          "price-api": {
            "Address": "https://localhost:7002/"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-api": {
            "Address": "https://localhost:7003/"
          }
        }
      },
      "ticket-cluster": {
        "Destinations": {
          "ticket-api": {
            "Address": "https://localhost:7004/"
          }
        }
      }
    }
  }
}